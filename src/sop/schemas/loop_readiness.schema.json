{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "loop_readiness.schema.json",
  "title": "LoopReadiness",
  "description": "Schema for loop_readiness_latest.json emitted by check_loop_readiness.py",
  "type": "object",
  "required": [
    "schema_version",
    "generated_at_utc",
    "skills_status",
    "loop_ready",
    "readiness_checks",
    "routing"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "description": "Schema version, must be '1.0'",
      "const": "1.0"
    },
    "generated_at_utc": {
      "type": "string",
      "description": "ISO-8601 UTC timestamp when the artifact was generated"
    },
    "skills_status": {
      "type": ["string", "null"],
      "description": "Raw skills_status value consumed from loop_cycle_summary_latest.json (null when key is absent)"
    },
    "loop_ready": {
      "type": "boolean",
      "description": "Whether the loop is ready to execute"
    },
    "readiness_checks": {
      "type": "array",
      "description": "List of individual readiness checks performed",
      "items": {
        "type": "object",
        "required": ["check", "result"],
        "additionalProperties": false,
        "properties": {
          "check": {
            "type": "string",
            "description": "Check identifier (e.g. skill_resolver_available)"
          },
          "result": {
            "type": "string",
            "enum": ["PASS", "FAIL", "SKIP"],
            "description": "Result of the check"
          },
          "reason": {
            "type": ["string", "null"],
            "description": "Human-readable reason for the result"
          }
        }
      }
    },
    "routing": {
      "type": "string",
      "enum": ["broken_install", "empty_by_design", "skills_active", "unknown"],
      "description": "Routing outcome derived from skills_status"
    },
    "operator_action": {
      "type": ["string", "null"],
      "description": "Operator action required, or null if none"
    }
  }
}
