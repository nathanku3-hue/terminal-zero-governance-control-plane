{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "LoopRunStepRecord",
  "description": "Schema for a single NDJSON line appended to loop_run_steps_latest.ndjson.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "trace_id",
    "name",
    "status",
    "exit_code",
    "started_utc",
    "ended_utc",
    "duration_seconds"
  ],
  "properties": {
    "trace_id": {
      "type": "string",
      "description": "Trace ID of the run that produced this step record."
    },
    "name": {
      "type": "string",
      "description": "Step name."
    },
    "status": {
      "type": "string",
      "enum": ["PASS", "FAIL", "ERROR", "SKIP", "HOLD"],
      "description": "Step execution status."
    },
    "exit_code": {
      "type": ["integer", "null"],
      "description": "Process exit code, or null for non-process steps."
    },
    "started_utc": {
      "type": "string",
      "description": "ISO 8601 UTC start timestamp."
    },
    "ended_utc": {
      "type": "string",
      "description": "ISO 8601 UTC end timestamp."
    },
    "duration_seconds": {
      "type": "number",
      "minimum": 0,
      "description": "Step duration in seconds."
    }
  }
}
