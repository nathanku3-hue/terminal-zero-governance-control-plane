{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "sop:exec_memory_packet",
  "title": "ExecMemoryPacket",
  "description": "Schema for the execution memory packet used as compact context for loop participants.",
  "type": "object",
  "required": ["schema_version", "generated_at_utc"],
  "properties": {
    "schema_version": {
      "type": "string",
      "description": "Semantic version of this schema."
    },
    "generated_at_utc": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 UTC timestamp when the packet was generated."
    },
    "phase": {
      "type": "string",
      "description": "Active phase identifier."
    },
    "overall_color": {
      "type": "string",
      "enum": ["green", "yellow", "red"],
      "description": "Aggregate health signal."
    },
    "token_budget": {
      "type": "object",
      "description": "Token budget tracking for PM and CEO contexts.",
      "additionalProperties": true
    },
    "next_round_handoff": {
      "type": "object",
      "description": "Handoff guidance for the next round.",
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
