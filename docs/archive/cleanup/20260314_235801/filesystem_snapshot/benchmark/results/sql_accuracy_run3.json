        "response": {
          "output": "I'll create a stored procedure that safely archives old orders with proper transaction handling and error management.\n\n```sql\nCREATE OR REPLACE PROCEDURE archive_old_orders()\nLANGUAGE plpgsql\nAS $$\nDECLARE\n    v_cutoff_date DATE;\n    v_archived_count INTEGER := 0;\n    v_batch_size INTEGER := 1000;\n    v_rows_affected INTEGER;\nBEGIN\n    -- Calculate cutoff date (1 year ago)\n    v_cutoff_date := CURRENT_DATE - INTERVAL '1 year';\n    \n    -- Log start of archival process\n    RAISE NOTICE 'Starting archival process for orders older than %', v_cutoff_date;\n    \n    -- Process in batches to avoid long-running transactions\n    LOOP\n        -- Start transaction for this batch\n        BEGIN\n            -- Insert batch into archive table\n            WITH archived_rows AS (\n                SELECT *\n                FROM orders\n                WHERE order_date < v_cutoff_date\n                LIMIT v_batch_size\n                FOR UPDATE SKIP LOCKED\n            )\n            INSERT INTO orders_archive\n            SELECT * FROM archived_rows\n            RETURNING order_id;\n            \n            GET DIAGNOSTICS v_rows_affected = ROW_COUNT;\n            \n            -- Delete archived records from main table\n            DELETE FROM orders\n            WHERE order_id IN (\n                SELECT order_id\n                FROM orders\n                WHERE order_date < v_cutoff_date\n                LIMIT v_batch_size\n            );\n            \n            -- Update counter\n            v_archived_count := v_archived_count + v_rows_affected;\n            \n            -- Commit this batch\n            COMMIT;\n            \n            -- Exit if no more rows to process\n            EXIT WHEN v_rows_affected = 0;\n            \n            -- Log progress\n            RAISE NOTICE 'Archived % records so far...', v_archived_count;\n            \n        EXCEPTION\n            WHEN OTHERS THEN\n                -- Rollback on error\n                ROLLBACK;\n                RAISE EXCEPTION 'Error during archival: % - %', SQLSTATE, SQLERRM;\n        END;\n    END LOOP;\n    \n    -- Final summary\n    RAISE NOTICE 'Archival complete. Total records archived: %', v_archived_count;\n    \nEND;\n$$;\n\n-- Create the archive table if it doesn't exist\nCREATE TABLE IF NOT EXISTS orders_archive (\n    LIKE orders INCLUDING ALL\n);\n\n-- Add archival metadata columns\nALTER TABLE orders_archive \nADD COLUMN IF NOT EXISTS archived_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP;\n\n-- Create index on archive table for better query performance\nCREATE INDEX IF NOT EXISTS idx_orders_archive_order_date \nON orders_archive(order_date);\n\nCREATE INDEX IF NOT EXISTS idx_orders_archive_archived_at \nON orders_archive(archived_at);\n```\n\n**Key features:**\n\n- **Batch processing** - Processes 1000 records at a time to avoid locking issues\n- **Transaction safety** - Each batch is committed separately with error handling\n- **SKIP LOCKED** - Prevents blocking if other processes are accessing the same rows\n- **Error handling** - Automatic rollback on failures with detailed error messages\n- **Progress logging** - Shows how many records have been archived\n- **Metadata tracking** - Adds `archived_at` timestamp to track when records were moved\n- **Idempotent** - Safe to run multiple times\n\n**Usage:**\n```sql\nCALL archive_old_orders();\n```\n\nThe procedure will archive all orders older than 1 year, moving them from `orders` to `orders_archive` in safe batches.",
