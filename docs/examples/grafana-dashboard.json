{
  "title": "Terminal Zero Governance — Starter Observability",
  "description": "Phase C starter dashboard (minimal)",
  "panels": [
    {
      "title": "Policy Decisions Total",
      "type": "timeseries",
      "expr": "sum by (decision) (policy_decisions_total)"
    },
    {
      "title": "Gate Evaluation Duration",
      "type": "timeseries",
      "expr": "sum by (gate) (gate_evaluation_duration_seconds)"
    },
    {
      "title": "Failure Count Total",
      "type": "stat",
      "expr": "failure_count_total"
    }
  ]
}
